# Frontend Environment Configuration
# Copy this file to .env for local development
# Vite only exposes variables prefixed with VITE_ to the browser

# --- Public site URL (SEO: canonical, Open Graph). Production: https://www.hakarursa.co.nz
# Use the same host you want as canonical (www or apex). Local: http://localhost:5173
# VITE_PUBLIC_SITE_URL=https://www.hakarursa.co.nz

# Optional absolute URL to a 1200×630 image for social previews (Open Graph / Twitter)
# VITE_PUBLIC_OG_IMAGE_URL=https://www.hakarursa.co.nz/your-og-image.jpg

# --- API Configuration ---
# Local: http://localhost:3001
# Production: Your Azure App Service URL (e.g., https://hakaru-api.azurewebsites.net)
VITE_API_BASE_URL=http://localhost:3001

# --- Stripe ---
# Get keys from https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Currency ---
VITE_CURRENCY=NZD
