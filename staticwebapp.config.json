{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/images/*", "/css/*", "/js/*", "/assets/*", "*.png", "*.jpg", "*.jpeg", "*.gif", "*.svg", "*.ico", "*.woff", "*.woff2", "*.ttf", "*.eot", "*.mp4", "*.webm"]
  },
  "mimeTypes": {
    ".json": "application/json"
  },
  "auth": {
    "identityProviders": {
      "azureActiveDirectory": {
        "registration": {
          "clientId": "${CLIENT_ID}",
          "clientSecret": "${CLIENT_SECRET}",
          "issuer": "${ISSUER}",
          "loginParameters": {
            "scope": ["openid", "profile", "email"]
          }
        }
      }
    }
  },
  "routes": [
    {
      "route": "/admin/login",
      "rewrite": "/.auth/login/aad"
    },
    {
      "route": "/admin/*",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/.auth/login/aad",
      "statusCode": "302",
      "redirect": "/admin/"
    },
    {
      "route": "/.auth/logout",
      "redirect": "/"
    }
  ]
}
