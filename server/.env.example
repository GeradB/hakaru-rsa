# Server Environment Configuration
# Copy this file to server/.env and fill in the values

# --- Azure Blob Storage (Gallery Images) ---
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_GALLERY_CONTAINER=gallery

# --- Admin Authentication ---
# Generate hash: cd server && node --input-type=module -e "import bcrypt from 'bcryptjs'; console.log(bcrypt.hashSync('YOUR_PASSWORD', 10));"
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=

# --- Cookie Settings ---
# Set true in production if served over HTTPS
COOKIE_SECURE=false

# --- CORS ---
# Comma-separated list of exact frontend origins (scheme + host + port, no trailing slash).
# REQUIRED for production: include every URL where the React app is hosted, e.g. Azure Static Web Apps:
#   FRONTEND_URLS=https://black-smoke-0c7710400.7.azurestaticapps.net,http://localhost:5173
# Preview environments get a new hostname per deployment — add each one, or use a stable custom domain.
FRONTEND_URLS=http://localhost:5173

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...

# --- Email (for membership confirmations) ---
EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# --- Database (Azure SQL) ---
SQL_SERVER_HOST=
SQL_SERVER_USER=
SQL_SERVER_PASSWORD=
SQL_SERVER_DATABASE=
SQL_SERVER_PORT=1433
