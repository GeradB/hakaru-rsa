# Server Environment Configuration
# Copy this file to server/.env and fill in the values

# --- Azure Blob Storage (Gallery Images) ---
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_GALLERY_CONTAINER=gallery

# --- Admin Authentication ---
# Generate hash: cd server && node --input-type=module -e "import bcrypt from 'bcryptjs'; console.log(bcrypt.hashSync('YOUR_PASSWORD', 10));"
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=

# --- Cookie Settings ---
# Set true in production if served over HTTPS
COOKIE_SECURE=false

# --- CORS ---
# Comma-separated frontend origins
FRONTEND_URLS=http://localhost:5173

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...

# --- Email (for membership confirmations) ---
EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# --- Database (Azure SQL) ---
SQL_SERVER_HOST=
SQL_SERVER_USER=
SQL_SERVER_PASSWORD=
SQL_SERVER_DATABASE=
SQL_SERVER_PORT=1433
