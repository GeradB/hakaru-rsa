# Server Environment Configuration
# Copy this file to server/.env and fill in the values

# --- Azure Blob Storage (Gallery Images) ---
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_GALLERY_CONTAINER=gallery

# --- Admin Authentication ---
# Generate hash: cd server && node --input-type=module -e "import bcrypt from 'bcryptjs'; console.log(bcrypt.hashSync('YOUR_PASSWORD', 10));"
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=

# --- Cookie Settings ---
# Set true in production if served over HTTPS
COOKIE_SECURE=false

# --- CORS ---
# Comma-separated list of exact frontend origins (scheme + host + port, no trailing slash).
# REQUIRED for production: include every URL where the React app is hosted, e.g. Azure Static Web Apps:
#   FRONTEND_URLS=https://black-smoke-0c7710400.7.azurestaticapps.net,http://localhost:5173
# Preview environments get a new hostname per deployment — add each one, or use a stable custom domain.
FRONTEND_URLS=http://localhost:5173

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...

# --- Email (Office 365 / Microsoft 365 SMTP) ---
# Optional display From. If different from EMAIL_USER, Exchange needs "Send As" or mail fails (554).
# If unset or different without Send As, the app sends From: EMAIL_USER (see EMAIL_FROM_TRUST_SEND_AS).
EMAIL_FROM=
# Set true only after M365 grants this mailbox Send As on EMAIL_FROM.
# EMAIL_FROM_TRUST_SEND_AS=false

# Admin notifications: distribution group or mailbox
EMAIL_TO=admin@yourdomain.co.nz

EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_USER=notifications@yourdomain.co.nz
EMAIL_PASS=

# Alternative: If using app-specific authentication
# For Microsoft 365, you may need to:
# 1. Enable SMTP AUTH for the mailbox in M365 Admin Center
# 2. Or use OAuth2 with Azure app registration (requires additional setup)

# --- Database (Azure SQL) ---
SQL_SERVER_HOST=
SQL_SERVER_USER=
SQL_SERVER_PASSWORD=
SQL_SERVER_DATABASE=
SQL_SERVER_PORT=1433
